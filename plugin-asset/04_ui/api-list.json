{
  "type": "page",
  "title": "列表",
  "remark": null,
  "name": "page-api",
  "toolbar": [
    {
      "type": "button",
      "actionType": "link",
      "link": "/entity/asset_api/new",
      "label": "手动录入",
      "primary": true
    }
  ],
  "body": [
    {
      "type": "crud",
      "name": "sample",
      "api": "/zenvis/api/v1/entity/asset_api/list",
      "quickSaveItemApi": "/zenvis/api/v1/entity/asset_api/$id/update",
      "autoGenerateFilter": true,
      "defaultParams": {
        "orderBy": "update_time",
        "orderDir": "desc"
      },
      "bulkActions": [
        {
          "label": "批量修改",
          "type": "button",
          "actionType": "dialog",
          "level": "light",
          "dialog": {
            "title": "批量编辑",
            "name": "sample-bulk-edit",
            "body": {
              "type": "form",
              "api": "/zenvis/api/v1/entity/asset_api/$ids/bulk_update",
              "controls": [
                {
                  "type": "input-tag",
                  "name": "label",
                  "searchable": true,
                  "clearable": true,
                  "source": "/zenvis/api/v1/entity/asset_api/label/list"
                },
                {
                  "type": "select",
                  "name": "level",
                  "label": "资产等级",
                  "searchable": true,
                  "source": "/zenvis/api/v1/entity/asset_api/level/list"
                },
                {
                  "type": "select",
                  "name": "type",
                  "label": "资产类型",
                  "searchable": true,
                  "source": "/zenvis/api/v1/entity/asset_api/type/list"
                },
                {
                  "type": "select",
                  "name": "owner",
                  "label": "资产归属",
                  "searchable": true,
                  "source": "/zenvis/api/v1/entity/asset_api/owner/list"
                },
                {
                  "type": "select",
                  "name": "status",
                  "label": "状态",
                  "searchable": true,
                  "source": "/zenvis/api/v1/entity/asset_api/status/list"
                },
                {
                  "type": "switch",
                  "name": "access",
                  "label": "是否可见"
                }
              ]
            }
          }
        },
        {
          "label": "批量删除",
          "type": "button",
          "level": "danger",
          "actionType": "ajax",
          "api": "delete:/zenvis/api/v1/entity/asset_api/bulk/$ids",
          "confirmText": "确定要批量删除?"
        }
      ],
      "columns": [
        {
          "type": "link",
          "href": "/#/device/index?id=${id}",
          "body": {
            "type": "tpl",
            "tpl": "${id|truncate:14}"
          },
          "name": "id",
          "label": "资产ID",
          "copyable": true
        },
        {
          "name": "update_time",
          "label": "活跃时间",
          "sortable": true,
          "searchable": {
            "type": "input-datetime-range",
            "name": "updateTime"
          }
        },
        {
          "name": "label",
          "label": "标签",
          "type": "tpl",
          "tpl": "<% if (data.label) { data.label.split(',').forEach(function(item) { %> <span class='label label-info m-l-sm'><%- item %></span> <% });} %>",
          "quickEdit": {
            "type": "input-tag",
            "placeholder": "",
            "clearable": true,
            "saveImmediately": true,
            "source": "/zenvis/api/v1/entity/asset_api/label/list"
          },
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "source": "/zenvis/api/v1/entity/asset_api/label/list"
          }
        },
        {
          "name": "api_name",
          "label": "名称",
          "searchable": {
            "type": "input-text",
            "name": "apiName",
            "autoComplete": "/zenvis/api/v1/entity/asset_api/auto_complete/api_name?term=$term"
          }
        },
        {
          "name": "api_version",
          "label": "版本",
          "searchable": {
            "type": "input-text",
            "name": "apiVersion",
            "autoComplete": "/zenvis/api/v1/entity/asset_api/api_version/auto-complete?term=$term"
          }
        },
        {
          "name": "api_path",
          "label": "路径",
          "searchable": {
            "type": "input-text",
            "name":"apiPath",
            "autoComplete": "/zenvis/api/v1/entity/asset_api/api_path/auto-complete?term=$term"
          }
        },
        {
          "name": "http_method",
          "label": "方法",
          "searchable": {
            "type": "input-text",
            "name": "httpMethod",
            "autoComplete": "/zenvis/api/v1/entity/asset_api/http_method/auto-complete?term=$term"
          }
        },
        {
          "name": "content_type",
          "label": "内容类型",
          "searchable": {
            "type": "input-text",
            "name": "contentType",
            "autoComplete": "/zenvis/api/v1/entity/asset_api/content_type/auto-complete?term=$term"
          }
        },
        {
          "name": "request_parameters",
          "label": "请求参数"
        },
        {
          "name": "response_format",
          "label": "响应格式",
          "toggled": false
        },
        {
          "name": "authentication_type",
          "label": "认证类型",
          "toggled": false
        },
        {
          "name": "rate_limit",
          "label": "速率限制",
          "toggled": false
        },
        {
          "name": "documentation_url",
          "label": "文档URL",
          "toggled": false
        },
        {
          "name": "service_id",
          "label": "所属服务",
          "searchable": true,
          "toggled": false
        },
        {
          "name": "is_deprecated",
          "label": "是否已弃用"
        },
        {
          "name": "level",
          "label": "重要等级",
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "source": "/zenvis/api/v1/entity/asset_api/level/list"
          }
        },
        {
          "name": "risk",
          "label": "风险等级",
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "source": "/zenvis/api/v1/entity/asset_api/risk/list"
          }
        },
        {
          "type": "tpl",
          "tpl": "${risk_info|truncate:2}",
          "name": "risk_info",
          "label": "风险详情",
          "popOver": {
            "body": {
              "type": "json",
              "value": "${risk_info}"
            }
          },
          "toggled": false
        },
        {
          "name": "net_type",
          "label": "网络类型",
          "toggled": false
        },
        {
          "name": "source",
          "label": "来源",
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "source": "/zenvis/api/v1/entity/asset_api/source/list"
          },
          "toggled": false
        },
        {
          "name": "owner",
          "label": "属主",
          "toggled": false,
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "source": "/zenvis/api/v1/entity/asset_api/owner/list"
          }
        },
        {
          "name": "access",
          "label": "是否开放",
          "type": "mapping",
          "map": {
            "true": "<span class='label label-warning'>开放</span>",
            "false": "<span class='label label-info'>不开放</span>",
            "*": "其他：${type}"
          },
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "options": [
              {
                "value": 1,
                "label": "开放"
              },
              {
                "value": 0,
                "label": "不开放"
              }
            ]
          },
          "toggled": false
        },
        {
          "name": "type",
          "label": "资产类型",
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "source": "/zenvis/api/v1/entity/asset_api/type/list"
          },
          "toggled": false
        },
        {
          "name": "status",
          "label": "状态",
          "searchable": {
            "type": "select",
            "searchable": true,
            "clearable": true,
            "source": "/zenvis/api/v1/entity/asset_api/status/list"
          },
          "toggled": false
        },
        {
          "name": "insert_time",
          "label": "入库时间",
          "searchable": {
            "type": "input-datetime-range",
            "name": "insertTime"
          },
          "toggled": false
        },
        {
          "type": "tpl",
          "tpl": "${info|truncate:2}",
          "name": "info",
          "label": "资产详情",
          "popOver": {
            "body": {
              "type": "json",
              "value": "${info}"
            }
          },
          "toggled": false
        },
        {
          "type": "operation",
          "label": "操作",
          "width": "",
          "buttons": [
            {
              "type": "button-group",
              "buttons": [
                {
                  "type": "button",
                  "label": "查看",
                  "level": "info",
                  "actionType": "link",
                  "link": "/api/${id}"
                },
                {
                  "type": "button",
                  "label": "修改",
                  "level": "warning",
                  "actionType": "link",
                  "link": "/api/${id}/edit"
                },
                {
                  "type": "button",
                  "label": "删除",
                  "level": "danger",
                  "actionType": "ajax",
                  "confirmText": "您确认要删除?",
                  "api": "delete:/zenvis/api/v1/entity/asset_api/$id"
                }
              ]
            }
          ],
          "placeholder": "-",
          "fixed": "right"
        }
      ],
      "affixHeader": true,
      "columnsTogglable": "auto",
      "placeholder": "暂无数据",
      "tableClassName": "table-db table-striped",
      "headerClassName": "crud-table-header",
      "footerClassName": "crud-table-footer",
      "toolbarClassName": "crud-table-toolbar",
      "combineNum": 0,
      "bodyClassName": "panel-default"
    }
  ]
}