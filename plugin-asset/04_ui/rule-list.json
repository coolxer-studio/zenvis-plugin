{
  "type": "page",
  "title": "规则列表",
  "remark": null,
  "toolbar": [
    {
      "type": "button",
      "actionType": "link",
      "link": "/asset/rule/new",
      "label": "添加规则",
      "primary": true
    }
  ],
  "body": {
    "type": "crud",
    "api": "/zenvis/api/v1/asset/rule/list",
    "mode": "cards",
    "defaultParams": {
      "perPage": 12
    },
    "filter": {
      "title": "搜索",
      "body": [
        {
          "type": "group",
          "body": [
            {
              "label": "资产",
              "type": "select",
              "name": "asset",
              "searchable": true,
              "clearable": true,
              "source": "/zenvis/api/v1/asset/class/list"
            },
            {
              "label": "执行",
              "type": "select",
              "name": "action",
              "searchable": true,
              "clearable": true,
              "source": "/zenvis/api/v1/asset/rule/action/list"
            },
            {
              "label": "状态",
              "type": "select",
              "name": "status",
              "searchable": true,
              "clearable": true,
              "source": "/zenvis/api/v1/asset/rule/status/list"
            }
          ]
        }
      ],
      "actions": [
        {
          "type": "reset",
          "label": "重置"
        },
        {
          "type": "submit",
          "level": "primary",
          "label": "查询"
        }
      ]
    },
    "bulkActions": [
      {
        "label": "批量删除",
        "actionType": "ajax",
        "api": "delete:/zenvis/api/v1/asset/rule/bulk/${ids|raw}",
        "confirmText": "确定要批量删除?"
      }
    ],
    "quickSaveItemApi": "/zenvis/api/v1/asset/rule/$id/update",
    "card": {
      "header": {
        "title": "$name",
        "subTitle": "$description",
        "subTitlePlaceholder": "暂无说明",
        "size": 60,
        "avatar": "<%= ((data.asset=='HOST') && \"data:image/svg+xml;base64,\")|| ((data.asset=='MOBILE') && \"data:image/svg+xml;base64,\") || ((data.asset=='PC') && \"data:image/svg+xml;base64,\") || ((data.asset=='IOT') && \"data:image/svg+xml;base64,\") || ((data.asset=='PROBE') && \"data:image/svg+xml;base64,\") || ((data.asset=='APP') && \"data:image/svg+xml;base64,\") || ((data.asset=='SERVICE') && \"data:image/svg+xml;base64,\") || ((data.asset=='API') && \"data:image/svg+xml;base64,\") || ((data.asset=='LOG') && \"data:image/svg+xml;base64,\") || ((data.asset=='FILE') && \"data:image/svg+xml;base64,\")%>",
        "avatarClassName": "pull-left thumb b-3x m-r"
      },
      "actions": [
        {
          "type": "button",
          "label": "修改规则",
          "icon": "fa fa-pencil",
          "actionType": "dialog",
          "dialog": {
            "title": "修改规则",
            "body": {
              "type": "form",
              "name": "sample-edit-form",
              "initApi": "/zenvis/api/v1/asset/rule/${id}/view",
              "api": "/zenvis/api/v1/asset/rule/${id}/update",
              "body": [
                {
                  "type": "condition-builder",
                  "hiddenOn": "asset != 'HOST'",
                  "label": "条件组件",
                  "name": "conditions",
                  "description": "可根据需求拼接查询条件",
                  "searchable": true,
                  "fields": [
                    {
                      "type": "select",
                      "name": "level",
                      "label": "资产等级",
                      "searchable": true,
                      "source": "/zenvis/api/v1/asset/level/list"
                    },
                    {
                      "type": "select",
                      "name": "type",
                      "label": "资产类型",
                      "searchable": true,
                      "source": "/zenvis/api/v1/asset/type/list"
                    },
                    {
                      "type": "select",
                      "name": "owner",
                      "label": "资产归属",
                      "searchable": true,
                      "source": "/zenvis/api/v1/asset/owner/list"
                    },
                    {
                      "type": "select",
                      "name": "status",
                      "label": "状态",
                      "searchable": true,
                      "source": "/zenvis/api/v1/asset/status/list"
                    },
                    {
                      "type": "select",
                      "name": "access",
                      "label": "是否开放",
                      "searchable": true,
                      "clearable": true,
                      "options": [
                        {
                          "value": 1,
                          "label": "开放"
                        },
                        {
                          "value": 0,
                          "label": "不开放"
                        }
                      ]
                    },
                    {
                      "label": "机房",
                      "type": "text",
                      "name": "room"
                    },
                    {
                      "label": "机柜号",
                      "type": "number",
                      "name": "cabinet_no"
                    },
                    {
                      "label": "机位号",
                      "type": "number",
                      "name": "cabinet_no"
                    },
                    {
                      "label": "厂商",
                      "type": "text",
                      "name": "manufacturer"
                    },
                    {
                      "label": "型号",
                      "type": "text",
                      "name": "model"
                    },
                    {
                      "label": "架构",
                      "type": "text",
                      "name": "architecture"
                    },
                    {
                      "label": "系统名称",
                      "type": "text",
                      "name": "system_name"
                    },
                    {
                      "label": "系统版本",
                      "type": "text",
                      "name": "system_version"
                    },
                    {
                      "label": "局域网IP",
                      "type": "text",
                      "name": "lan_ip"
                    },
                    {
                      "label": "外网IP",
                      "type": "text",
                      "name": "wan_ip"
                    },
                    {
                      "label": "风险信息",
                      "type": "text",
                      "name": "risk_info"
                    },
                    {
                      "label": "资产详情",
                      "type": "text",
                      "name": "info"
                    },
                    {
                      "label": "时间",
                      "children": [
                        {
                          "label": "活跃日期",
                          "type": "datetime",
                          "name": "update_time"
                        },
                        {
                          "label": "首次日期",
                          "type": "datetime",
                          "name": "insert_time"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          }
        },
        {
          "type": "button",
          "label": "删除",
          "icon": "fa fa-trash",
          "actionType": "ajax",
          "confirmText": "您确认要删除?",
          "api": "delete:/zenvis/api/v1/asset/rule/$id"
        }
      ],
      "body": [
        {
          "name": "status",
          "label": "状态",
          "type": "mapping",
          "map": {
            "INACTIVE": "<span class='label label-info'>未激活</span>",
            "ACTIVE": "<span class='label label-success'>激活</span>",
            "UNAVAILABLE": "<span class='label label-danger'>不可用</span>",
            "EXPIRED": "<span class='label label-warning'>失效</span>",
            "*": "<span class='label label-default'>其他</span>"
          },
          "quickEdit": {
            "type": "select",
            "clearable": true,
            "saveImmediately": true,
            "source": "/zenvis/api/v1/asset/rule/status/list"
          }
        },
        {
          "name": "asset_desc",
          "label": "资产对象",
          "type": "text"
        },
        {
          "type": "tpl",
          "tpl": "${conditions | json |truncate:20}",
          "name": "conditions",
          "label": "判断规则",
          "popOver": {
            "body": {
              "type": "json",
              "value": "${conditions | json}"
            }
          }
        },
        {
          "name": "action_desc",
          "label": "执行动作",
          "type": "text"
        },
        {
          "type": "tpl",
          "tpl": "${result|truncate:20}",
          "name": "result",
          "label": "执行结果",
          "popOver": {
            "body": {
              "type": "text",
              "value": "${result}"
            }
          }
        },
        {
          "name": "create_time",
          "label": "创建时间"
        },
        {
          "name": "update_time",
          "label": "更新时间"
        }
      ]
    }
  }
}