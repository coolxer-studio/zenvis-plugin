            },
            {
              "style": {
                "padding": "10px 5px",
                "margin": "5px",
                "borderRadius": "14px",
                "border": "1px solid #f0f0f0",
                "backgroundColor": "#ffffff"
              },
              "type": "tpl",
              "tpl": "<div style='display: flex;'><div style='display: flex;justify-content: center;align-items: center;'><i class='fa-solid fa-mobile'></i></div><div style='flex: 1;display: flex;flex-direction: column;justify-content: center;padding: 0 16px;'><div style='text-align: right;color: #708090; font-weight: bold;font-size: 8px;'>近增:${asset_mobile_increase}</div><div style='font-weight: bold;font-size: 12px;'>移动端设备</div><div style='text-align: center; font-size: 20px; color: #B0E0E6; font-weight: bold;'>${asset_mobile}</div></div>"
            },
            {
              "style": {
                "padding": "10px 5px",
                "margin": "5px",
                "borderRadius": "14px",
                "border": "1px solid #f0f0f0",
                "backgroundColor": "#ffffff"
              },
              "type": "tpl",
              "tpl": "<div style='display: flex;'><div style='display: flex;justify-content: center;align-items: center;'><i class='fa-solid fa-laptop'></i></div><div style='flex: 1;display: flex;flex-direction: column;justify-content: center;padding: 0 16px;'><div style='text-align: right;color: #708090; font-weight: bold;font-size: 8px;'>近增:${asset_pc_increase}</div><div style='font-weight: bold;font-size: 12px;'>PC端设备</div><div style='text-align: center; font-size: 20px; color: #87CEEB; font-weight: bold;'>${asset_pc}</div></div>"
            },
            {
              "style": {
                "padding": "10px 5px",
                "margin": "5px",
                "borderRadius": "14px",
                "border": "1px solid #f0f0f0",
                "backgroundColor": "#ffffff"
              },
              "type": "tpl",
              "tpl": "<div style='display: flex;'><div style='display: flex;justify-content: center;align-items: center;'><i class='fa-solid fa-vector-square'></i></div><div style='flex: 1;display: flex;flex-direction: column;justify-content: center;padding: 0 16px;'><div style='text-align: right;color: #708090; font-weight: bold;font-size: 8px;'>近增:${asset_iot_increase}</div><div style='font-weight: bold;font-size: 12px;'>IOT设备</div><div style='text-align: center; font-size: 20px; color: #87CEEB; font-weight: bold;'>${asset_iot}</div></div>"
            },
            {
              "style": {
                "padding": "10px 5px",
                "margin": "5px",
                "borderRadius": "14px",
                "border": "1px solid #f0f0f0",
                "backgroundColor": "#ffffff"
              },
              "type": "tpl",
              "tpl": "<div style='display: flex;'><div style='display: flex;justify-content: center;align-items: center;'><i class='fa-solid fa-atom'></i></div><div style='flex: 1;display: flex;flex-direction: column;justify-content: center;padding: 0 16px;'><div style='text-align: right;color: #708090; font-weight: bold;font-size: 8px;'>近增:${asset_probe_increase}</div><div style='font-weight: bold;font-size: 12px;'>探针资产</div><div style='text-align: center; font-size: 20px; color: #4682B4; font-weight: bold;'>${asset_probe}</div></div>"
            },
            {
              "style": {
                "padding": "10px 5px",
                "margin": "5px",
                "borderRadius": "14px",
                "border": "1px solid #f0f0f0",
                "backgroundColor": "#ffffff"
              },
              "type": "tpl",
              "tpl": "<div style='display: flex;'><div style='display: flex;justify-content: center;align-items: center;'><i class='fa-brands fa-dropbox'></i></div><div style='flex: 1;display: flex;flex-direction: column;justify-content: center;padding: 0 16px;'><div style='text-align: right;color: #708090; font-weight: bold;font-size: 8px;'>近增:${asset_app_increase}</div><div style='font-weight: bold;font-size: 12px;'>应用资产</div><div style='text-align: center; font-size: 20px; color: #4682B4; font-weight: bold;'>${asset_app}</div></div>"
            },
            {
              "style": {
                "padding": "10px 5px",
                "margin": "5px",
                "borderRadius": "14px",
                "border": "1px solid #f0f0f0",
                "backgroundColor": "#ffffff"
              },
              "type": "tpl",
              "tpl": "<div style='display: flex;'><div style='display: flex;justify-content: center;align-items: center;'><i class='fa-solid fa-layer-group'></i></div><div style='flex: 1;display: flex;flex-direction: column;justify-content: center;padding: 0 16px;'><div style='text-align: right;color: #708090; font-weight: bold;font-size: 8px;'>近增:${asset_service_increase}</div><div style='font-weight: bold;font-size: 12px;'>服务资产</div><div style='text-align: center; font-size: 20px; color: #48D1CC; font-weight: bold;'>${asset_service}</div></div>"
            },
            {
              "style": {
                "padding": "10px 5px",
                "margin": "5px",
                "borderRadius": "14px",
                "border": "1px solid #f0f0f0",
                "backgroundColor": "#ffffff"
              },
              "type": "tpl",
              "tpl": "<div style='display: flex;'><div style='display: flex;justify-content: center;align-items: center;'><i class='fa-solid fa-shuffle'></i></div><div style='flex: 1;display: flex;flex-direction: column;justify-content: center;padding: 0 16px;'><div style='text-align: right;color: #708090; font-weight: bold;font-size: 8px;'>近增:${asset_api_increase}</div><div style='font-weight: bold;font-size: 12px;'>API资产</div><div style='text-align: center; font-size: 20px; color: #48D1CC; font-weight: bold;'>${asset_api}</div></div>"
