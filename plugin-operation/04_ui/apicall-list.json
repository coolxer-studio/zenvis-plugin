{
  "type": "page",
  "title": "列表",
  "remark": null,
  "name": "page-api_call",
  "body": [
    {
      "type": "crud",
      "name": "sample",
      "api": "/zenvis/api/v1/entity/operation_api_call_event/list",
      "quickSaveItemApi": "/zenvis/api/v1/entity/operation_api_call_event/$id/update",
      "autoGenerateFilter": true,
      "defaultParams": {
        "orderBy": "update_time",
        "orderDir": "desc"
      },
      "bulkActions": [
        {
          "label": "批量标记",
          "type": "button",
          "actionType": "dialog",
          "level": "light",
          "dialog": {
            "title": "批量标记",
            "name": "sample-bulk-edit",
            "body": {
              "type": "form",
              "api": "/zenvis/api/v1/entity/operation_api_call_event/$ids/bulk_update",
              "controls": [
                {
                  "type": "input-tag",
                  "name": "label",
                  "searchable": true,
                  "clearable": true,
                  "source": "/zenvis/api/v1/entity/operation_api_call_event/label/list"
                }
              ]
            }
          }
        }
      ],
      "columns": [
        {
          "type": "link",
          "href": "/#/device/index?id=${id}",
          "body": {
            "type": "tpl",
            "tpl": "${id|truncate:14}"
          },
          "name": "id",
          "label": "事件ID",
          "copyable": true
        },
        {
          "name": "event_time",
          "label": "发生时间",
          "sortable": true,
          "searchable": {
            "type": "input-datetime-range",
            "name": "eventTime"
          }
        },
        {
          "name": "caller",
          "label": "调用对象",
          "searchable": {
            "type": "input-text",
            "name": "caller",
            "autoComplete": "/zenvis/api/v1/entity/operation_api_call_event/caller/auto-complete?term=$term"
          }
        },
        {
          "name": "callee",
          "label": "被调用对象",
          "searchable": {
            "type": "input-text",
            "name": "callee",
            "autoComplete": "/zenvis/api/v1/entity/operation_api_call_event/callee/auto-complete?term=$term"
          }
        },
        {
          "name": "function_name",
          "label": "函数名",
          "searchable": {
            "type": "input-text",
            "name": "function_name",
            "autoComplete": "/zenvis/api/v1/entity/operation_api_call_event/function_name/auto-complete?term=$term"
          }
        },
        {
          "name": "function_params",
          "label": "参数"
        },
        {
          "name": "function_return",
          "label": "返回值"
        },
        {
          "type": "link",
          "href": "/#/device/index?id=${user_id}",
          "body": {
            "type": "tpl",
            "tpl": "${user_id|truncate:14}"
          },
          "name": "user_id",
          "label": "用户ID",
          "copyable": true
        },
        {
          "type": "link",
          "href": "/#/device/index?id=${app_id}",
          "body": {
            "type": "tpl",
            "tpl": "${app_id|truncate:14}"
          },
          "name": "app_id",
          "label": "应用ID",
          "copyable": true
        },
        {
          "name": "location",
          "label": "位置",
          "searchable": {
            "name": "areaCode",
            "type": "input-city",
            "itemClassName": "min-w-xs",
            "size": "full",
            "searchable": true
          }
        },
        {
          "name": "wan_ip",
          "label": "外网IP",
          "copyable": true,
          "searchable": true
        },
        {
          "name": "lan_ip",
          "label": "内网IP",
          "copyable": true,
          "searchable": true
        },
        {
          "name": "net_type",
          "label": "网络类型",
          "toggled": false
        },
        {
          "name": "insert_time",
          "label": "入库时间",
          "searchable": {
            "type": "input-datetime-range",
            "name": "insertTime"
          },
          "toggled": false
        },
        {
          "name": "update_time",
          "label": "活跃时间",
          "sortable": true,
          "searchable": {
            "type": "input-datetime-range",
            "name": "updateTime"
          },
          "toggled": false
        },
        {
          "type": "operation",
          "label": "操作",
          "width": "",
          "buttons": [
            {
              "type": "button-group",
              "buttons": [
                {
                  "type": "button",
                  "icon": "fa fa-eye",
                  "actionType": "link",
                  "link": "/apicall/${id}"
                }
              ]
            }
          ],
          "placeholder": "-",
          "fixed": "right"
        }
      ],
      "affixHeader": true,
      "columnsTogglable": "auto",
      "placeholder": "暂无数据",
      "tableClassName": "table-db table-striped",
      "headerClassName": "crud-table-header",
      "footerClassName": "crud-table-footer",
      "toolbarClassName": "crud-table-toolbar",
      "combineNum": 0,
      "bodyClassName": "panel-default"
    }
  ]
}