                                  ]
                                },
                                "series": [
                                  {
                                    "name": "转化率",
                                    "type": "funnel",
                                    "left": "10%",
                                    "top": 60,
                                    "bottom": 60,
                                    "width": "80%",
                                    "height": "50%",
