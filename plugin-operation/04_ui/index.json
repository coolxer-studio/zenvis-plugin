                                      1500,
                                      1600,
                                      1700,
                                      1800,
                                      1900,
                                      2000,
                                      2100,
                                      2200,
                                      2300
                                    ]
                                  }
                                ]
                              }
                            }
                          ]
                        },
                        {
                          "title": "折线图",
                          "icon": "fas fa-chart-line",
                          "tab": [
                            {
                              "type": "chart",
                              "config": {
                                "title": {
                                  "text": "用户活跃度趋势",
                                  "left": "center"
                                },
                                "tooltip": {
