                                      }
                                    ],
                                    "emphasis": {
                                      "itemStyle": {
                                        "shadowBlur": 10,
                                        "shadowOffsetX": 0,
                                        "shadowColor": "rgba(0, 0, 0, 0.5)"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        },
                        {
                          "title": "柱状图",
                          "value": "bar",
                          "icon": "fas fa-chart-bar",
                          "tab": [
                            {
                              "type": "chart",
                              "config": {
                                "title": {
                                  "text": "月度营销活动效果",
                                  "left": "center"
                                },
                                "tooltip": {
                                  "trigger": "axis",
                                  "axisPointer": {
                                    "type": "shadow"
                                  }
