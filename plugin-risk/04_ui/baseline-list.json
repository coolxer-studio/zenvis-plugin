{
  "type": "page",
  "title": "列表",
  "remark": null,
  "name": "page-baseline",
  "body": [
    {
      "type": "crud",
      "name": "sample",
      "api": "/zenvis/api/v1/entity/risk_baseline/list",
      "quickSaveItemApi": "/zenvis/api/v1/entity/risk_baseline/$id/update",
      "autoGenerateFilter": true,
      "defaultParams": {
        "orderBy": "update_time",
        "orderDir": "desc"
      },
      "bulkActions": [
        {
          "label": "批量标记",
          "type": "button",
          "actionType": "dialog",
          "level": "light",
          "dialog": {
            "title": "批量标记",
            "name": "sample-bulk-edit",
            "body": {
              "type": "form",
              "api": "/zenvis/api/v1/operati/baseline/$ids/bulk_update",
              "controls": [
                {
                  "type": "input-tag",
                  "name": "label",
                  "searchable": true,
                  "clearable": true,
                  "source": "/zenvis/api/v1/entity/risk_baseline/label/list"
                }
              ]
            }
          }
        }
      ],
      "columns": [
        {
          "type": "link",
          "href": "/#/device/index?id=${id}",
          "body": {
            "type": "tpl",
            "tpl": "${id|truncate:14}"
          },
          "name": "id",
          "label": "事件ID",
          "copyable": true
        },
        {
          "name": "event_time",
          "label": "发生时间",
          "sortable": true,
          "searchable": {
            "type": "input-datetime-range",
            "name": "eventTime"
          }
        },
        {
          "name": "configuration_name",
          "label": "配置项名称",
          "searchable": {
            "type": "input-text",
            "name": "configurationName",
            "autoComplete": "/zenvis/api/v1/entity/risk_baseline/configuration_name/auto-complete?term=$term"
          }
        },
        {
          "name": "expected_value",
          "label": "预期配置值",
          "searchable": {
            "type": "input-text",
            "name": "expectedValue",
            "autoComplete": "/zenvis/api/v1/entity/risk_baseline/expected_value/auto-complete?term=$term"
          }
        },
		{
          "name": "current_value",
          "label": "当前配置值",
          "searchable": {
            "type": "input-text",
            "name": "currentValue",
            "autoComplete": "/zenvis/api/v1/entity/risk_baseline/current_value/auto-complete?term=$term"
          }
        },
				{
          "name": "verification_method",
          "label": "验证方法"
        },
		{
          "name": "verification_result",
          "label": "验证结果"
        },
		{
          "name": "label",
          "label": "标签"
        },
		{
          "name": "risk_level",
          "label": "风险等级"
        },
        {
          "type": "link",
          "href": "/#/device/index?id=${user_id}",
          "body": {
            "type": "tpl",
            "tpl": "${user_id|truncate:14}"
          },
          "name": "user_id",
          "label": "用户ID",
          "copyable": true
        },
        {
          "type": "link",
          "href": "/#/device/index?id=${asset_id}",
          "body": {
            "type": "tpl",
            "tpl": "${asset_id|truncate:14}"
          },
          "name": "asset_id",
          "label": "资产ID",
          "copyable": true
        },
        {
          "type": "link",
          "href": "/#/device/index?id=${start_id}",
          "body": {
            "type": "tpl",
            "tpl": "${start_id|truncate:14}"
          },
          "name": "start_id",
          "label": "启动ID",
          "copyable": true
        },
        {
          "name": "location",
          "label": "位置",
          "searchable": {
            "name": "areaCode",
            "type": "input-city",
            "itemClassName": "min-w-xs",
            "size": "full",
            "searchable": true
          }
        },
        {
          "name": "wan_ip",
          "label": "外网IP",
          "copyable": true,
          "searchable": true
        },
        {
          "name": "lan_ip",
          "label": "内网IP",
          "copyable": true,
          "searchable": true
        },
        {
          "name": "net_type",
          "label": "网络类型",
          "toggled": false
        },
        {
          "name": "insert_time",
          "label": "入库时间",
          "searchable": {
            "type": "input-datetime-range",
            "name": "insertTime"
          },
          "toggled": false
        },
        {
          "name": "update_time",
          "label": "活跃时间",
          "sortable": true,
          "searchable": {
            "type": "input-datetime-range",
            "name": "updateTime"
          },
          "toggled": false
        },
        {
          "type": "operation",
          "label": "操作",
          "width": "",
          "buttons": [
            {
              "type": "button-group",
              "buttons": [
                {
                  "type": "button",
                  "icon": "fa fa-eye",
                  "actionType": "link",
                  "link": "/baseline/${id}"
                }
              ]
            }
          ],
          "placeholder": "-",
          "fixed": "right"
        }
      ],
      "affixHeader": true,
      "columnsTogglable": "auto",
      "placeholder": "暂无数据",
      "tableClassName": "table-db table-striped",
      "headerClassName": "crud-table-header",
      "footerClassName": "crud-table-footer",
      "toolbarClassName": "crud-table-toolbar",
      "combineNum": 0,
      "bodyClassName": "panel-default"
    }
  ]
}